---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/site';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const poster = project.data.demoMedia.poster || project.data.cover;
const previewImage = project.data.demoMedia.previewAnimation || poster;
---

<article class="project-card demo-project-card">
  <a class="demo-preview" href={withBase(`projects/${project.id}/#demo-walkthrough`)} aria-label={`观看${project.data.title}演示`}>
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={withBase(poster)}
      aria-label={`${project.data.title} GIF 预览`}
    >
      {project.data.demoMedia.previewVideo && <source src={withBase(project.data.demoMedia.previewVideo)} type="video/mp4" />}
    </video>
    {!project.data.demoMedia.previewVideo && <img src={withBase(previewImage)} alt="" loading="lazy" />}
    <span class="project-number">{project.data.eyebrow}</span>
    <span class="preview-label">GIF Preview / 演示预览</span>
  </a>
  <div class="card-body">
    <div class="meta-row">
      {project.data.year && <span>{project.data.year}</span>}
      <span class="status-group">
        {project.data.statuses.map((status) => <span class="status-badge" data-status={status}>{status}</span>)}
      </span>
    </div>
    <h3><a href={withBase(`projects/${project.id}/`)}>{project.data.title}</a></h3>
    <p class="project-one-line">{project.data.oneLine}</p>
    <p class="project-privacy-line">演示均使用虚构或脱敏数据，不展示真实业务材料。</p>
    <div class="project-card-actions">
      <a class="button primary" href={withBase(`projects/${project.id}/#demo-walkthrough`)}>观看演示</a>
      <a class="button quiet" href={withBase(`projects/${project.id}/#sample-output`)}>查看样例输出</a>
    </div>
  </div>
</article>
